     48 +def _mean_squared_error(a: List[List[float]], b: List[List[float]]) -> float:
     49 +    """Mean squared error between two batches of vectors."""
     50 +    total = 0.0
     51 +    count = 0
     52 +    for va, vb in zip(a, b):
     53 +        for xa, xb in zip(va, vb):
     54 +            diff = xa - xb
     55 +            total += diff * diff
     56 +            count += 1
     57 +    if count == 0:
     58 +        return 0.0
     59 +    return total / count

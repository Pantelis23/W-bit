     62 +def quantize_weights(W: Sequence[Sequence[float]], R: int) -> Tuple[List[List[float]], List[float]]:
     63 +    """
     64 +    Quantize weights into R evenly spaced levels between -max_abs and +max_abs.
     65 +
     66 +    Args:
     67 +        W: 2D weight matrix.
     68 +        R: number of discrete states.
     69 +
     70 +    Returns:
     71 +        (quantized_weights, levels)
     72 +    """
     73 +    if R < 2:
     74 +        raise ValueError("R must be >= 2 for quantization")
     75 +
     76 +    W_list = _to_list_matrix(W)
     77 +    max_abs = 0.0
     78 +    for row in W_list:
     79 +        for w in row:
     80 +            max_abs = max(max_abs, abs(w))
     81 +    if max_abs == 0.0:
     82 +        max_abs = 1e-6
     83 +
     84 +    step = (2 * max_abs) / (R - 1)
     85 +    levels = [(-max_abs + i * step) for i in range(R)]
     86 +
     87 +    def snap(value: float) -> float:
     88 +        best = levels[0]
     89 +        best_dist = abs(value - best)
     90 +        for lvl in levels[1:]:
     91 +            dist = abs(value - lvl)
     92 +            if dist < best_dist:
     93 +                best = lvl
     94 +                best_dist = dist
     95 +        return best
     96 +
     97 +    quantized = []
     98 +    for row in W_list:
     99 +        quantized.append([snap(w) for w in row])
    100 +
    101 +    return quantized, levels
